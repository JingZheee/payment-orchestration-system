{
  "info": {
    "name": "Payment Orchestration System",
    "_postman_id": "pos-collection-v1",
    "description": "Full API collection for the Payment Orchestration System FYP demo.\n\nQuick start:\n1. Run 'Auth / Login' — accessToken and refreshToken are saved automatically.\n2. Run 'Payments / Initiate Payment (MY)' — transactionId is saved automatically.\n3. Explore Dashboard and Admin endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",              "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "accessToken",          "value": "", "type": "string" },
    { "key": "refreshToken",         "value": "", "type": "string" },
    { "key": "transactionId",        "value": "", "type": "string" },
    { "key": "providerTransactionId","value": "", "type": "string" },
    { "key": "feeRateId",            "value": "1", "type": "string" },
    { "key": "routingRuleId",        "value": "1", "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"password123\",\n  \"role\": \"ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Register (MERCHANT)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@demo.com\",\n  \"password\": \"password123\",\n  \"role\": \"MERCHANT\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  console.log('Token saved:', json.data.accessToken.substring(0,20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth","refresh"] }
          }
        }
      ]
    },

    {
      "name": "Payments",
      "item": [
        {
          "name": "Get Payment Methods — MY",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/payments/methods?region=MY&amount=500.00",
              "host": ["{{baseUrl}}"], "path": ["payments","methods"],
              "query": [
                { "key": "region", "value": "MY" },
                { "key": "amount", "value": "500.00" }
              ]
            }
          }
        },
        {
          "name": "Get Payment Methods — ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/payments/methods?region=ID&amount=100000",
              "host": ["{{baseUrl}}"], "path": ["payments","methods"],
              "query": [
                { "key": "region", "value": "ID" },
                { "key": "amount", "value": "100000" }
              ]
            }
          }
        },
        {
          "name": "Get Payment Methods — PH",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/payments/methods?region=PH&amount=1000.00",
              "host": ["{{baseUrl}}"], "path": ["payments","methods"],
              "query": [
                { "key": "region", "value": "PH" },
                { "key": "amount", "value": "1000.00" }
              ]
            }
          }
        },
        {
          "name": "Initiate Payment — MY (FPX)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('idempotencyKey', pm.utils.guid());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('transactionId',         json.data.transactionId);",
                  "  pm.collectionVariables.set('providerTransactionId', json.data.providerTransactionId || '');",
                  "  console.log('Transaction ID:', json.data.transactionId);",
                  "  console.log('Routed to:', json.data.provider, 'via', json.data.routingStrategy);",
                  "  console.log('Reason:', json.data.routingReason);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",   "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantOrderId\": \"ORDER-MY-001\",\n  \"amount\": \"500.00\",\n  \"currency\": \"MYR\",\n  \"region\": \"MY\",\n  \"paymentMethod\": \"FPX\",\n  \"customerEmail\": \"customer@test.com\",\n  \"description\": \"Test payment Malaysia FPX\",\n  \"redirectUrl\": \"http://localhost:4200/payment/result\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/payments/initiate", "host": ["{{baseUrl}}"], "path": ["payments","initiate"] }
          }
        },
        {
          "name": "Initiate Payment — ID (Virtual Account)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('idempotencyKey', pm.utils.guid());"]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('transactionId',         json.data.transactionId);",
                  "  pm.collectionVariables.set('providerTransactionId', json.data.providerTransactionId || '');",
                  "  console.log('Routed to:', json.data.provider, 'via', json.data.routingStrategy);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",   "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantOrderId\": \"ORDER-ID-001\",\n  \"amount\": \"150000\",\n  \"currency\": \"IDR\",\n  \"region\": \"ID\",\n  \"paymentMethod\": \"VIRTUAL_ACCOUNT\",\n  \"customerEmail\": \"customer@test.com\",\n  \"description\": \"Test payment Indonesia Virtual Account\",\n  \"redirectUrl\": \"http://localhost:4200/payment/result\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/payments/initiate", "host": ["{{baseUrl}}"], "path": ["payments","initiate"] }
          }
        },
        {
          "name": "Initiate Payment — PH (Maya)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('idempotencyKey', pm.utils.guid());"]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('transactionId',         json.data.transactionId);",
                  "  pm.collectionVariables.set('providerTransactionId', json.data.providerTransactionId || '');",
                  "  console.log('Routed to:', json.data.provider, 'via', json.data.routingStrategy);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",   "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantOrderId\": \"ORDER-PH-001\",\n  \"amount\": \"1000.00\",\n  \"currency\": \"PHP\",\n  \"region\": \"PH\",\n  \"paymentMethod\": \"MAYA\",\n  \"customerEmail\": \"customer@test.com\",\n  \"description\": \"Test payment Philippines Maya\",\n  \"redirectUrl\": \"http://localhost:4200/payment/result\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/payments/initiate", "host": ["{{baseUrl}}"], "path": ["payments","initiate"] }
          }
        },
        {
          "name": "Get Transaction + Event Log",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/payments/{{transactionId}}", "host": ["{{baseUrl}}"], "path": ["payments","{{transactionId}}"] }
          }
        }
      ]
    },

    {
      "name": "Admin — Providers",
      "item": [
        {
          "name": "List All Providers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/providers", "host": ["{{baseUrl}}"], "path": ["admin","providers"] }
          }
        },
        {
          "name": "Disable BILLPLZ",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/providers/BILLPLZ/toggle?enabled=false",
              "host": ["{{baseUrl}}"], "path": ["admin","providers","BILLPLZ","toggle"],
              "query": [{ "key": "enabled", "value": "false" }]
            }
          }
        },
        {
          "name": "Enable BILLPLZ",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/providers/BILLPLZ/toggle?enabled=true",
              "host": ["{{baseUrl}}"], "path": ["admin","providers","BILLPLZ","toggle"],
              "query": [{ "key": "enabled", "value": "true" }]
            }
          }
        },
        {
          "name": "Disable MOCK",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/providers/MOCK/toggle?enabled=false",
              "host": ["{{baseUrl}}"], "path": ["admin","providers","MOCK","toggle"],
              "query": [{ "key": "enabled", "value": "false" }]
