            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/providers/MOCK/toggle?enabled=true",
              "host": ["{{baseUrl}}"], "path": ["admin","providers","MOCK","toggle"],
              "query": [{ "key": "enabled", "value": "true" }]
            }
          }
        }
      ]
    },

    {
      "name": "Admin — Fee Rates",
      "item": [
        {
          "name": "List All Fee Rates (with region)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('feeRateId', String(json.data[0].id));",
                  "  console.log('First fee rate ID saved:', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/fee-rates", "host": ["{{baseUrl}}"], "path": ["admin","fee-rates"] }
          }
        },
        {
          "name": "Update Fee Rate (percentage)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"percentage\": 0.020000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/admin/fee-rates/{{feeRateId}}", "host": ["{{baseUrl}}"], "path": ["admin","fee-rates","{{feeRateId}}"] }
          }
        },
        {
          "name": "Update Fee Rate (fixed amount)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fixedAmount\": 2.0000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/admin/fee-rates/{{feeRateId}}", "host": ["{{baseUrl}}"], "path": ["admin","fee-rates","{{feeRateId}}"] }
          }
        }
      ]
    },

    {
      "name": "Admin — Routing Rules",
      "item": [
        {
          "name": "List All Rules",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('routingRuleId', String(json.data[0].id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/routing-rules", "host": ["{{baseUrl}}"], "path": ["admin","routing-rules"] }
          }
        },
        {
          "name": "Create Rule — Force BILLPLZ for MY",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) pm.collectionVariables.set('routingRuleId', String(json.data.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priority\": 1,\n  \"region\": \"MY\",\n  \"preferredProvider\": \"BILLPLZ\",\n  \"enabled\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/admin/routing-rules", "host": ["{{baseUrl}}"], "path": ["admin","routing-rules"] }
          }
        },
        {
          "name": "Create Rule — LOWEST_FEE for large ID payments",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) pm.collectionVariables.set('routingRuleId', String(json.data.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priority\": 2,\n  \"region\": \"ID\",\n  \"minAmount\": 500000,\n  \"strategy\": \"LOWEST_FEE\",\n  \"enabled\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/admin/routing-rules", "host": ["{{baseUrl}}"], "path": ["admin","routing-rules"] }
          }
        },
        {
          "name": "Create Rule — SUCCESS_RATE catch-all for PH",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priority\": 10,\n  \"region\": \"PH\",\n  \"strategy\": \"SUCCESS_RATE\",\n  \"enabled\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/admin/routing-rules", "host": ["{{baseUrl}}"], "path": ["admin","routing-rules"] }
          }
        },
        {
          "name": "Update Rule",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priority\": 1,\n  \"region\": \"MY\",\n  \"strategy\": \"SUCCESS_RATE\",\n  \"enabled\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/admin/routing-rules/{{routingRuleId}}", "host": ["{{baseUrl}}"], "path": ["admin","routing-rules","{{routingRuleId}}"] }
          }
        },
        {
          "name": "Delete Rule",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/routing-rules/{{routingRuleId}}", "host": ["{{baseUrl}}"], "path": ["admin","routing-rules","{{routingRuleId}}"] }
          }
        }
      ]
    },

