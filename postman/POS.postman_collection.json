        },
        {
          "name": "Live Scores — MY",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/dashboard/scores?region=MY&amount=500.00&currency=MYR&paymentMethod=FPX",
              "host": ["{{baseUrl}}"], "path": ["admin","dashboard","scores"],
              "query": [
                { "key": "region",        "value": "MY" },
