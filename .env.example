# Copy this file to .env on the VPS and fill in real values
# Never commit .env to git

# Database
DB_PASSWORD=change_me_strong_password

# RabbitMQ
RABBITMQ_USER=pos
RABBITMQ_PASS=change_me_strong_password

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=change_me_64_char_base64_secret

# Email (Mailtrap sandbox or real SMTP)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password

# Mailpit web UI basic auth (http://<vps-ip>:8025), format user:password
MAILPIT_UI_AUTH=admin:change_me_strong_password

# Billplz
BILLPLZ_API_KEY=your_billplz_api_key
BILLPLZ_COLLECTION_ID=your_collection_id
BILLPLZ_WEBHOOK_SECRET=your_webhook_secret

# Midtrans
MIDTRANS_SERVER_KEY=your_server_key
MIDTRANS_CLIENT_KEY=your_client_key
MIDTRANS_WEBHOOK_SECRET=your_webhook_secret

# PayMongo
PAYMONGO_SECRET_KEY=your_secret_key
PAYMONGO_WEBHOOK_SECRET=your_webhook_secret

# Xendit
XENDIT_SECRET_KEY=your_xendit_secret_key
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token

# Frontend URL (used in payment retry/failure emails)
APP_BASE_URL=https://your-frontend-domain.com
